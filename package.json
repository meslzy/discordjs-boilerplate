    "module-alias": "^2.2.2",
    "winston": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.5",
    "@typescript-eslint/eslint-plugin": "^5.30.6",
    "@typescript-eslint/parser": "^5.30.6",
    "eslint": "^8.20.0",
    "nodemon": "^2.0.19",
    "typescript": "^4.7.4"
  },
  "engines": {
